;;;; src/crypto/aes.lisp — AES-256-CBC encryption (FIPS 197)
;;;; Full implementation: key expansion, encrypt/decrypt blocks, CBC mode, PKCS7 padding.
;;;; No external dependencies. Pure Common Lisp on SBCL.
(in-package :cauldron.crypto)

